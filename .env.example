# =========================================================================
# JOBGUARD ENVIRONMENT VARIABLES (TEMPLATE)
# =========================================================================

# Application settings
PORT=8080
NODE_ENV=development
JWT_SECRET=jobguard-super-secret-dev-key-12345

# SendGrid SMTP Credentials
# Host and User are pre-configured for SendGrid. Just supply API Key & verified Sender Email.
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=SG.xxxxx_your_sendgrid_api_key_goes_here
SENDGRID_FROM_EMAIL=your-verified-sender@yourdomain.com

# Twilio SMS Credentials
# Leave blank to disable SMS verification and run in email-only mode
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_goes_here
TWILIO_PHONE_NUMBER=+1234567890
